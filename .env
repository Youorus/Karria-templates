# .env.example — Copie en .env et complète les valeurs obligatoires.
# Toutes les variables sont lues UNE SEULE FOIS dans config.py.

# ─── OBLIGATOIRE ───────────────────────────────────────────────────────────
GEMINI_API_KEY=AIzaSyBqYxkNsP5d4TfWsOCkZg8f7iKmWYX-nlQ

# ─── GEMINI ────────────────────────────────────────────────────────────────
GEMINI_MODEL=gemini-2.5-pro
MAX_OUTPUT_TOKENS=32000
TEMPERATURE=0.15
MAX_RETRIES=2

# ─── PDF / ANALYSE ─────────────────────────────────────────────────────────
DPI=200

# ─── CHEMINS ───────────────────────────────────────────────────────────────
# OUTPUT_DIR    : dossier où generate() écrit les templates générés
OUTPUT_DIR=./outputs

# PDF_SEARCH_DIR : dossier affiché par défaut dans le navigateur interactif
PDF_SEARCH_DIR=./templates

# KARRIA_TEMPLATES_ROOT : racine du navigateur pour submit_template --batch
# Par défaut = OUTPUT_DIR si non défini
# KARRIA_TEMPLATES_ROOT=./outputs

# ─── PIPELINE ──────────────────────────────────────────────────────────────
# Active la passe 2 visual critic (compare HTML rendu vs PDF original)
ENABLE_VISUAL_CRITIC=true

# Port du serveur de preview côte-à-côte
PREVIEW_PORT=8765

# ─── API KARRIA (lues par modules/karria_api/) ─────────────────────────────
# Ces variables sont lues par core/settings.py (ton projet global), pas par
# config.py du générateur. Mets-les ici pour avoir tout au même endroit.

KARRIA_BASE_URL=http://127.0.0.1:8000
KARRIA_API_PREFIX=/api/v1
KARRIA_CLIENT_ID=karria-job-ingestor
KARRIA_CLIENT_SECRET=Karria_q-jPHmf8FWxkl2t4vcv59HAQ_V0C0WBG
KARRIA_SCOPE="companies:read companies:write templates:read templates:write"
